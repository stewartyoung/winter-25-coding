      "seed": 862742046,
      "version": 150,
      "versionNonce": 135466014,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775033716368,
      "link": null,
      "locked": false,
      "text": "Url Shortener\n\n1. Requirements\n2. Core entities\n3. API or interface\n4. High level design\n5. Deep dives (NFR)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Url Shortener\n\n1. Requirements\n2. Core entities\n3. API or interface\n4. High level design\n5. Deep dives (NFR)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "oPYKFcPVob1Xkp66B9y-j",
      "type": "text",
      "x": -269.47544202827174,
      "y": 24.08010333624145,
      "width": 808.8633422851562,
      "height": 260,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0J",
      "roundness": null,
      "seed": 15194334,
      "version": 960,
      "versionNonce": 394855490,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775035291594,
      "link": null,
      "locked": false,
      "text": "Functional requirements\n- create a short url from a long url\n    - optionally: set an expiration time\n    - optionally: set a custom alias\n- get long url redirect from the short url\n\nNon-functional requirements\n- Low latency to redirect\n- Scalability: 100M daily users, 1 Bn URLs\n- Ensure uniqueness of short code - no collisions\n- Given partition tolerance, must tradeoff between consistency or availability\n    - We will prioritise availability over consistency\n    we are not dealing with booking tickets, changing bank balances, so we don't need strong consitency",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional requirements\n- create a short url from a long url\n    - optionally: set an expiration time\n    - optionally: set a custom alias\n- get long url redirect from the short url\n\nNon-functional requirements\n- Low latency to redirect\n- Scalability: 100M daily users, 1 Bn URLs\n- Ensure uniqueness of short code - no collisions\n- Given partition tolerance, must tradeoff between consistency or availability\n    - We will prioritise availability over consistency\n    we are not dealing with booking tickets, changing bank balances, so we don't need strong consitency",
      "autoResize": true,
      "lineHeight": 1.25
    },
