    {
      "id": "cyJZtu8OQuyw2SaHSvpEt",
      "type": "text",
      "x": 1471.1253668345819,
      "y": 2134.329151290861,
      "width": 587.85546875,
      "height": 260,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
