    {
      "id": "KXhd8S5LmwBEqf0LmpkPD",
      "type": "text",
      "x": 43.70071270170769,
      "y": 998.3245780154381,
      "width": 569.3755493164062,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0p",
      "roundness": null,
      "seed": 996111746,
      "version": 536,
      "versionNonce": 654597918,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775039466213,
      "link": null,
      "locked": false,
      "text": "GET\n- 301 redirect - permanent redirect based on cache\n    - can be stored in browser cache so it doesn't even go to yours first\n- 302 redirect\n    - can allow us to store analytics where we can track number of visits",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "GET\n- 301 redirect - permanent redirect based on cache\n    - can be stored in browser cache so it doesn't even go to yours first\n- 302 redirect\n    - can allow us to store analytics where we can track number of visits",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "nSlDPKombRD6Nhwro4uNv",
      "type": "text",
      "x": 70.82993393323571,
      "y": 850.0335000940341,
      "width": 660.111328125,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0q",
      "roundness": null,
      "seed": 2136673154,
      "version": 247,
      "versionNonce": 1806093150,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775039466213,
      "link": null,
      "locked": false,
      "text": "POST\n- 409 conflict - custom alias already exists\n- 400 bad request - bad expirationTime, custom alias validation fails (e.g. bad word)\n- 201 created - short URL created",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "POST\n- 409 conflict - custom alias already exists\n- 400 bad request - bad expirationTime, custom alias validation fails (e.g. bad word)\n- 201 created - short URL created",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "bGBTIVO1EmQSSIa34C2mP",
      "type": "text",
      "x": -310.85569513615053,
      "y": 494.95864970590605,
      "width": 183.45582580566406,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0r",
      "roundness": null,
      "seed": 1846556126,
      "version": 111,
      "versionNonce": 1781811166,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775036793263,
      "link": null,
      "locked": false,
      "text": "API\n\n// shorten a URL\nPOST /urls -> shortUrl\n{\n    originalUrl,\n    customAlias?,\n    expiry?\n}\n\n// get\nGET /urls/{userId}\n\n// redirection\nGET /{shortPath}",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API\n\n// shorten a URL\nPOST /urls -> shortUrl\n{\n    originalUrl,\n    customAlias?,\n    expiry?\n}\n\n// get\nGET /urls/{userId}\n\n// redirection\nGET /{shortPath}",
      "autoResize": true,
      "lineHeight": 1.25
    },
