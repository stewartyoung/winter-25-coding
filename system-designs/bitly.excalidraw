      "isDeleted": false,
      "boundElements": null,
      "updated": 1775039466213,
      "link": null,
      "locked": false,
      "text": "Url Table\n- shortUrl (PK)\n- longUrl\n- expirationTime?\n- customAlias?\n- creationTime\n- userId\n\nBalanced tree index from PK on URL O(log(n)) \nlookup for shortUrl query",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Url Table\n- shortUrl (PK)\n- longUrl\n- expirationTime?\n- customAlias?\n- creationTime\n- userId\n\nBalanced tree index from PK on URL O(log(n)) \nlookup for shortUrl query",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "hB-UgeW06v1vaO36r7GXF",
