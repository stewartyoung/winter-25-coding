      "link": null,
      "locked": false,
      "text": "GET\n- 301 redirect - permanent redirect based on cache\n    - can be stored in browser cache so it doesn't even go to yours first\n- 302 redirect\n    - can allow us to store analytics where we can track number of visits",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "GET\n- 301 redirect - permanent redirect based on cache\n    - can be stored in browser cache so it doesn't even go to yours first\n- 302 redirect\n    - can allow us to store analytics where we can track number of visits",
      "autoResize": true,
      "lineHeight": 1.25
    },
