      "text": "POST\n- 409 conflict - custom alias already exists\n- 400 bad request - bad expirationTime, custom alias validation fails (e.g. bad word)\n- 201 created - short URL created",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "POST\n- 409 conflict - custom alias already exists\n- 400 bad request - bad expirationTime, custom alias validation fails (e.g. bad word)\n- 201 created - short URL created",
      "autoResize": true,
      "lineHeight": 1.25
    },
