    {
      "id": "kedMuv7U3swgiFB2vgWHc",
      "type": "text",
      "x": 1536.580899427859,
      "y": 640.7752339678691,
      "width": 368.1437072753906,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
